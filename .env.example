# Comma-separated list of folders containing your videos (default: ~/Movies)
LIBRARY_DIRS=/Users/you/Movies,/Users/you/Downloads/clips

# Where original Apple aerial videos are backed up before being overwritten
# (default: ~/.aerial-manager/backups)
#BACKUP_DIR=/Users/you/.aerial-manager/backups

# Explicit ffmpeg binary path (default: auto-detect homebrew, /usr/local, then PATH)
#FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
